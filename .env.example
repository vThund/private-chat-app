# PeerJS Server Configuration
# These environment variables control where the app connects for peer signaling

# PRE-CONFIGURED: Uses free PeerJS Cloud (no setup needed)
# To use PeerJS Cloud, simply leave these commented out

# VITE_PEER_HOST=api.peerjs.com
# VITE_PEER_PORT=443
# VITE_PEER_SECURE=true
# VITE_PEER_PATH=/

# ALTERNATIVE: Self-hosted PeerJS server
# If you're running your own PeerJS server, uncomment and update these:
# VITE_PEER_HOST=your-server.com
# VITE_PEER_PORT=9000
# VITE_PEER_SECURE=true
# VITE_PEER_PATH=/peerjs
